# ─── Community Hub (hub-server.js / Prisma / Coolify) ──────────────────────
# PostgreSQL connection string for the Community Hub.
# Supports Neon, Supabase, Railway, Coolify-managed PostgreSQL, or any standard
# PostgreSQL instance.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jtl_hub?schema=public"

# Hub server port (optional, default: 3002)
HUB_PORT=3002

# Comma-separated list of allowed CORS origins.
# Leave empty / unset to allow all origins (recommended for a public hub).
# ALLOWED_ORIGINS=https://jtl.yourdomain.com

# Shared secret required to call destructive/admin hub routes (e.g. DELETE a
# flow) via the `x-admin-key` header. Unset = those routes are disabled.
# HUB_ADMIN_KEY=

# ─── Vite build variables (baked into the JS bundle at build time) ──────────
# Empty string (default) = bridge routes are on the same origin as the hub.
# Set only if you run the bridge on a completely separate host/port.
VITE_BRIDGE_URL=

# Hub the frontend talks to for Community browsing/publishing.
# Defaults to the general public hub — swap it for your own hub's URL (or
# leave empty for same-origin, if you're running the combined self-host
# image with your own DATABASE_URL) if you don't want to use ours.
VITE_HUB_URL=https://db-flow.remotatech.com

# Local MSSQL bridge port used in development (default: 3001)
PORT=3001

# ─── MSSQL credentials ─────────────────────────────────────────────────────
# Do NOT add MSSQL credentials here.
# Enter DB_HOST / DB_PORT / DB_INSTANCE / DB_USER / DB_PASS in the browser
# Settings panel — they are encrypted with AES-256-GCM and stored only in
# the browser (localStorage/sessionStorage). Nothing is persisted server-side.
